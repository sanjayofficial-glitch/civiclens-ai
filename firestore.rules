rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : 'citizen';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isModerator() {
      return role() in ['moderator', 'official', 'government', 'admin'];
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isPrivileged() {
      return isModerator() || isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn() || isPrivileged();
      allow create: if isOwner(userId) || isPrivileged();
      allow update: if isOwner(userId) || isPrivileged();
      allow delete: if isAdmin();

      match /settings/{settingId} {
        allow read, write: if isOwner(userId) || isPrivileged();
      }
    }

    match /issues/{issueId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isPrivileged() || (signedIn() && resource.data.reporterId == request.auth.uid);
      allow delete: if isPrivileged() || (signedIn() && resource.data.reporterId == request.auth.uid);
    }

    match /votes/{voteId} {
      allow read: if signedIn() || isPrivileged();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isPrivileged() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isPrivileged() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if (signedIn() && resource.data.userId == request.auth.uid) || isPrivileged();
      allow create: if false;
      allow update: if (signedIn() && resource.data.userId == request.auth.uid) || isPrivileged();
      allow delete: if (signedIn() && resource.data.userId == request.auth.uid) || isPrivileged();
    }

    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if isPrivileged();
    }

    match /analytics/{docId} {
      allow read: if isPrivileged();
      allow write: if false;
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
