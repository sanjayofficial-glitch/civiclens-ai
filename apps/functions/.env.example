# =============================================================================
# CivicLens — Cloud Functions Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values for local development.
# For production deployment, set these via:
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:config:set gemini.model="gemini-1.5-flash"

# ── Gemini AI ────────────────────────────────────────────────────────────
# Required. Get your API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Optional overrides ──────────────────────────────────────────────────
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_TIMEOUT_MS=20000
# GEMINI_MAX_RETRIES=2
