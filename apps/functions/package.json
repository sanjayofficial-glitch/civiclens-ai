{
    "name":  "@civiclens/functions",
    "version":  "1.0.0",
    "description":  "Cloud Functions for CivicLens",
    "main":  "lib/index.js",
    "scripts":  {
                    "lint":  "eslint \"src/**/*\"",
                    "test":  "vitest run",
                    "build":  "npm --prefix ../../packages/shared run build \u0026\u0026 tsc",
                    "serve":  "npm run build \u0026\u0026 firebase emulators:start --only functions",
                    "shell":  "npm run build \u0026\u0026 firebase functions:shell",
                    "start":  "npm run shell",
                    "deploy":  "firebase deploy --only functions",
                    "logs":  "firebase functions:log"
                },
    "engines":  {
                    "node":  "22"
                },
    "dependencies":  {
                         "@civiclens/shared": "file:./shared",
                         "firebase-admin":  "^12.7.0",
                         "firebase-functions":  "^6.6.0",
                         "zod":  "^3.24.1"
                     },
    "devDependencies":  {
                            "@types/node":  "^20.0.0",
                            "fast-check":  "^3.22.0",
                            "typescript":  "^5.6.0",
                            "vitest":  "^4.1.9"
                        },
    "private":  true
}