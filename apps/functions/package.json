{
  "name": "@blockseblock/functions",
  "version": "1.0.0",
  "description": "Cloud Functions for BlockSeBlock",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint \"src/**/*\"",
    "test": "vitest run",
    "build": "npm --prefix ../../packages/shared run build && tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@blockseblock/shared": "*",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "private": true
}
