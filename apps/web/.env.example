# =============================================================================
# CivicLens — Web App Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Firebase Configuration ──────────────────────────────────────────────
# Get these from your Firebase project: ⚙️ → Project settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# ── Gemini AI (Client-side fallback, optional) ──────────────────────────
# Only needed if you want to keep the client-side SDK fallback.
# For production, route AI through the server-side callable instead.
# Get your API key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── UI Dev Mode (optional, bypasses auth in development) ──────────────────
# VITE_UI_DEV_MODE=true
