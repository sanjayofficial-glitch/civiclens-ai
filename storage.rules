rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() { return request.auth != null; }
    function isOwner(uid) { return isAuthenticated() && request.auth.uid == uid; }
    
    function isValidMedia() {
      return (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'))
             && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false; 
    }

    match /users/{userId} {
      match /avatars/{imageId} {
        allow read: if true; 
        allow write: if isOwner(userId) && request.resource.contentType.matches('image/.*') && request.resource.size < 5 * 1024 * 1024;
      }
      
      match /uploads/{fileId} {
        allow read: if isAuthenticated(); 
        allow write: if isOwner(userId) && isValidMedia();
      }
    }
  }
}
